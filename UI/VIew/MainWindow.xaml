<Window x:Class="UI.VIew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI.VIew"
        mc:Ignorable="d"
        Title="MainWindow" Height="446" Width="357"
        xmlns:VM="clr-namespace:UI.ViewModel">
    <Grid>
        <StackPanel Orientation="Horizontal" Margin="105,50,0,0" VerticalAlignment="Top">
            <Label Content="User Name" Width="70"/>
            <TextBox TextWrapping="Wrap" Width="170" Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="105,94,0,0" VerticalAlignment="Top" Height="27">
            <Label Content="Password" Width="70"/>
            <TextBox TextWrapping="Wrap" Width="170" Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        <StackPanel Margin="105,135,0,243" Orientation="Horizontal">
            <Label Content="Role" Width="70"/>
            <ComboBox HorizontalAlignment="Left" ItemsSource="{Binding UserRoles}" SelectedItem="{Binding UserSelectedRole}"  VerticalAlignment="Top" Width="146" Height="21"/>
        </StackPanel>
        <Button Content="Register" HorizontalAlignment="Left" Margin="178,250,0,0" VerticalAlignment="Top" Height="44" Width="146" Command="{Binding RegisterUserCommand}" CommandParameter="{Binding .}"/>
        <Button Content="Log In" HorizontalAlignment="Left" Margin="28,250,0,0" VerticalAlignment="Top" Height="44" Width="145" Command="{Binding LogInCommand}" CommandParameter="{Binding .}"/>
        <Button Content="View database" HorizontalAlignment="Left" Margin="100,299,0,0" VerticalAlignment="Top" Height="44" Width="146" Command="{Binding ViewDatabaseCommand}"/>
    </Grid>
</Window>
